# Proxy Configuration
# Copy this file to .env and adjust values as needed

# Backend: 'vertex' (GCP Vertex AI) or 'bedrock' (AWS Bedrock)
PROXY_BACKEND=vertex

# --- Vertex AI settings (when PROXY_BACKEND=vertex) ---
# GCP project ID (required for vertex)
VERTEX_PROJECT_ID=your-gcp-project-id
# Primary Vertex AI region
VERTEX_REGION=us-east5
# Fallback region (used when primary returns 5xx)
VERTEX_FALLBACK_REGION=us-central1
# Path to GCP credentials (optional — uses ADC default if not set)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# --- Bedrock settings (when PROXY_BACKEND=bedrock) ---
# AWS region (uses default credential chain: env vars, instance profile, etc.)
# AWS_REGION=us-east-1
# AWS_FALLBACK_REGION=us-west-2
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# --- Shared settings ---
# Proxy listening port
PROXY_PORT=4100
# Max concurrent requests (returns 429 when exceeded)
VERTEX_MAX_CONCURRENT=20
# Verbose logging (request sizes, latency)
# VERTEX_DEBUG=1
